rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Functionalities Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserBengkelId() {
      return request.auth.token.bengkelId;
    }

    function isOwner() {
      return request.auth.token.role == 'owner';
    }

    function isStaff() {
      return request.auth.token.role == 'staff';
    }

    // Bengkel Collection
    match /bengkel/{bengkelId} {
      // Any authenticated user can create a bengkel
      allow create: if isSignedIn();
      // Any authenticated user can check if a bengkel exists or get its basic info
      allow get: if isSignedIn();
      // Only users belonging to this bengkel can list/query it
      allow list: if isSignedIn() && getUserBengkelId() == bengkelId;
      // Only the owner of the bengkel can write/update it
      allow update, delete: if isSignedIn() && getUserBengkelId() == bengkelId && isOwner();
      
      // Staff-specific permissions helper
      function hasStaffPermission(permission) {
        let staffDoc = get(/databases/$(database)/documents/bengkel/$(bengkelId)/staff/$(request.auth.uid));
        // Check customPermissions map directly
        let hasCustom = staffDoc.data.customPermissions != null && staffDoc.data.customPermissions[permission] == true;
        // If has roleTemplateId, we might need another check, but for now focus on customPermissions
        // which serves as the override and primary point of truth for staff.
        return hasCustom;
      }

      // Nested collections inside Bengkel (Transactions, Stok, Pelanggan, Staff)
      // SEC-FIX: S-02 Granular Staff Write Permissions
      match /transactions/{documentId} {
        allow read: if isSignedIn() && getUserBengkelId() == bengkelId;
        allow create: if isSignedIn() && getUserBengkelId() == bengkelId && (isOwner() || hasStaffPermission('transaksi_create'));
        allow update: if isSignedIn() && getUserBengkelId() == bengkelId && (isOwner() || hasStaffPermission('transaksi_update'));
        allow delete: if isSignedIn() && getUserBengkelId() == bengkelId && isOwner();
      }

      match /stok/{documentId} {
        allow read: if isSignedIn() && getUserBengkelId() == bengkelId;
        allow create: if isSignedIn() && getUserBengkelId() == bengkelId && (isOwner() || hasStaffPermission('stok_create'));
        allow update: if isSignedIn() && getUserBengkelId() == bengkelId && (isOwner() || hasStaffPermission('stok_update_jumlah'));
        allow delete: if isSignedIn() && getUserBengkelId() == bengkelId && isOwner();
      }

      match /secrets/{documentId} {
        allow read: if isSignedIn() && getUserBengkelId() == bengkelId && isOwner();
        allow create: if isSignedIn() && (
          (getUserBengkelId() == bengkelId && isOwner()) ||
          (getAfter(/databases/$(database)/documents/bengkel/$(bengkelId)).data.ownerUid == request.auth.uid)
        );
        allow update: if isSignedIn() && getUserBengkelId() == bengkelId && isOwner();
      }

      match /{subcollection}/{documentId} {
        allow read: if isSignedIn() && getUserBengkelId() == bengkelId;
        allow write: if isSignedIn() && getUserBengkelId() == bengkelId && isOwner();
      }
    }

    // Top-level collections partitioned by `bengkelId` field.
    // SEC-FIX: T-01 null resource check — consistently used for all operations.

    function getIncomingBengkelId() {
      return request.resource != null && request.resource.data != null ? request.resource.data.bengkelId : null;
    }

    function resourceMatchesBengkel(bengkelId) {
      let incomingId = getIncomingBengkelId();
      return (request.method == 'create' && incomingId == bengkelId)
          || (resource != null && resource.data != null && resource.data.bengkelId == bengkelId);
    }

    match /transactions/{id} {
      allow read: if isSignedIn() && resourceMatchesBengkel(getUserBengkelId());
      allow create: if isSignedIn() && getIncomingBengkelId() == getUserBengkelId();
      allow update: if isSignedIn() && resourceMatchesBengkel(getUserBengkelId())
                    && getIncomingBengkelId() == getUserBengkelId();
      allow delete: if isSignedIn() && isOwner() && resourceMatchesBengkel(getUserBengkelId());
    }

    match /stok/{id} {
      allow read: if isSignedIn() && resourceMatchesBengkel(getUserBengkelId());
      allow create: if isSignedIn() && getIncomingBengkelId() == getUserBengkelId();
      allow update: if isSignedIn() && resourceMatchesBengkel(getUserBengkelId())
                    && getIncomingBengkelId() == getUserBengkelId();
      allow delete: if isSignedIn() && isOwner() && resourceMatchesBengkel(getUserBengkelId());
    }

    match /pelanggans/{id} {
      allow read: if isSignedIn() && resourceMatchesBengkel(getUserBengkelId());
      allow create: if isSignedIn() && (isOwner() || isStaff()) && getIncomingBengkelId() == getUserBengkelId();
      allow update: if isSignedIn() && (isOwner() || isStaff())
                    && resourceMatchesBengkel(getUserBengkelId())
                    && getIncomingBengkelId() == getUserBengkelId();
      allow delete: if isSignedIn() && isOwner() && resourceMatchesBengkel(getUserBengkelId());
    }
    
    match /staff/{id} {
      allow read: if isSignedIn() && resourceMatchesBengkel(getUserBengkelId());
      allow create: if isSignedIn() && isOwner() && getIncomingBengkelId() == getUserBengkelId();
      allow update: if isSignedIn() && isOwner()
                    && resourceMatchesBengkel(getUserBengkelId())
                    && getIncomingBengkelId() == getUserBengkelId();
      allow delete: if isSignedIn() && isOwner() && resourceMatchesBengkel(getUserBengkelId());
    }

    // 👤 Users / Profiles collection
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    // 🛠️ Internal configuration (Read only for authenticated users)
    match /_internal/{configId} {
      allow read: if isSignedIn();
    }
  }
}

